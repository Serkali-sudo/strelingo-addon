# Strelingo Addon Configuration
# Copy this file to .env and configure your settings

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Port for the addon server (default: 7000)
PORT=7000

# Custom addon name (default: "Strelingo - Dual Language Subtitles")
# Useful for distinguishing self-hosted instances in Stremio
# ADDON_NAME=Self-Hosted Strelingo

# External URL for accessing the addon remotely
# Use this if your Stremio is running on a different device
# Examples:
#   - Local network: http://192.168.1.100:7000
#   - Public domain: https://strelingo.example.com
#   - Ngrok tunnel: https://abc123.ngrok.io
# EXTERNAL_URL=http://localhost:7000

# Signs lazy subtitle URLs so users cannot put arbitrary subtitle fetch
# targets into the /serve-subtitles URL. Vercel Blob and S3 secret keys can
# also be used for signing automatically. Direct-serving installs without
# those storage keys should set this explicitly.
# SUBTITLE_PAYLOAD_SECRET=change_this_to_a_long_random_secret

# ============================================================================
# STORAGE OPTIONS (Choose one)
# ============================================================================

# --- Option 1: Vercel Blob Storage (Cloud) ---
# Get your token from: https://vercel.com/dashboard/stores
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxx

# ...or uncomment the next line to skip Vercel Blob and use other storage options
# SKIP_VERCEL_BLOB=true

# --- Option 2: S3-Compatible Storage (Cloud / self-hosted) ---
# Works with AWS S3, Cloudflare R2, Supabase Storage S3, Backblaze B2,
# DigitalOcean Spaces, Wasabi, MinIO, and other S3-compatible providers.
#
# SDK connection settings:
# - S3_ENDPOINT is required for R2, Supabase S3, Spaces, B2, Wasabi, MinIO, etc.
# - S3_ENDPOINT can usually be omitted for regular AWS S3.
# - S3_REGION is "auto" for Cloudflare R2; use your provider's region otherwise.
# S3_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=strelingo-subtitles
# S3_ACCESS_KEY_ID=xxxxxxxxxxxxx
# S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxx
#
# App URL settings:
# S3_PUBLIC_BASE_URL is not an AWS SDK setting. It is the public-read URL
# base returned to Stremio for stored subtitles. Use a custom domain, public
# bucket URL, r2.dev URL, or Supabase public object base URL.
# S3_PUBLIC_BASE_URL=https://subtitles.example.com
#
# Optional object prefix/folder inside the bucket:
# S3_PREFIX=strelingo
#
# Path-style requests work best across generic S3-compatible providers.
# Set to false only when your provider requires virtual-host style URLs.
# S3_FORCE_PATH_STYLE=true

# --- Option 3: Local File Storage (Self-hosted) ---
# Path to store subtitle files locally (creates directory if it doesn't exist)
# Examples:
#   - Relative path: ./subtitles
#   - Absolute path: /var/www/strelingo/subtitles
# LOCAL_STORAGE_DIR=./subtitles

# ============================================================================
# DIRECT SERVING (Alternative to Storage)
# ============================================================================

# Serve merged subtitles directly from the addon itself. Generated URLs are
# signed and merged lazily when Stremio requests the subtitle.
# Requires SUBTITLE_PAYLOAD_SECRET unless BLOB_READ_WRITE_TOKEN or
# S3_SECRET_ACCESS_KEY is configured.
# ENABLE_DIRECT_SERVING=true

# For storage modes, return signed lazy URLs in the subtitle list. On click,
# the addon checks storage, merges only if missing, stores, then redirects to
# the stored subtitle URL. Leave false/unset to process missing subtitles
# during the subtitle-listing request.
# ENABLE_STORAGE_LAZY_SERVING=true

# ============================================================================
# USAGE EXAMPLES
# ============================================================================

# Example 1: Vercel Blob only (simplest for cloud hosting)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxx

# Example 2: S3-compatible storage only
# SKIP_VERCEL_BLOB=true
# S3_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=strelingo-subtitles
# S3_ACCESS_KEY_ID=xxxxxxxxxxxxx
# S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxx
# S3_PUBLIC_BASE_URL=https://subtitles.example.com

# Example 3: Local storage only (no cloud dependencies)
# SKIP_VERCEL_BLOB=true
# LOCAL_STORAGE_DIR=./subtitles
# EXTERNAL_URL=http://192.168.1.100:7000
