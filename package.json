{
  "name": "strelingo-addon",
  "version": "0.1.0",
  "description": "Stremio addon (Strelingo) for dual language subtitles using OpenSubtitles",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "npx tsx src/index.ts",
    "dev": "wrangler dev src/index.ts",
    "dev:node": "npx tsx watch src/index.ts",
    "build": "tsc",
    "deploy": "wrangler deploy src/index.ts",
    "deploy:vercel": "vercel --prod",
    "test": "npx tsx test/encoding.test.ts && npx tsx test/e2e.test.ts",
    "test:encoding": "npx tsx test/encoding.test.ts",
    "test:e2e": "npx tsx test/e2e.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "2.0.2",
    "@supabase/supabase-js": "2.105.4",
    "@vercel/blob": "2.3.3",
    "chardet": "2.1.1",
    "franc-all": "7.2.0",
    "hono": "4.12.19",
    "iconv-lite": "0.7.2",
    "iso-639-3": "3.0.1",
    "pako": "2.1.0",
    "srt-parser-2": "1.2.3",
    "tsx": "4.22.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260518.1",
    "typescript": "6.0.3",
    "wrangler": "4.92.0"
  },
  "engines": {
    "node": ">=18"
  }
}