{
  "name": "strelingo-addon",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-07",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": false,
  "observability": {
    "enabled": true
  },
  "cache": {
    "enabled": true
  },
  "vars": {
    "ENABLE_DIRECT_SERVING": "true"
  }
}